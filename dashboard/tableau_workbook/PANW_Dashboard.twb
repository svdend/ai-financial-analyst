            <column caption='Gross Margin %' datatype='real' name='[Calculation_4390148998500353]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [line_item] = &apos;GrossProfit&apos; THEN [Calculation_4390148995850240] END)&#10;  / SUM(IF [line_item] = &apos;Revenue&apos; THEN [Calculation_4390148995850240] END)' />
            </column>
            <column caption='Operating Margin %' datatype='real' name='[Calculation_4390148998676482]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [line_item] = &apos;OperatingIncome&apos; THEN [Calculation_4390148995850240] END)&#10;  / SUM(IF [line_item] = &apos;Revenue&apos; THEN [Calculation_4390148995850240] END)' />
            </column>
            <column caption='Net Margin %' datatype='real' name='[Calculation_4390148998766595]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [line_item] = &apos;NetIncome&apos; THEN [Calculation_4390148995850240] END)&#10;  / SUM(IF [line_item] = &apos;Revenue&apos; THEN [Calculation_4390148995850240] END)' />
